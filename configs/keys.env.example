[TEMPLATE]
# ── LLM Provider Keys ───────────────────────────────────────────────────────
# Choose ONE based on your provider setting in settings.yaml:

# For provider: "deepseek" (default) — Direct DeepSeek API (fast, simple)
DEEPSEEK_API_KEY=replace_me

# For provider: "agentrouter" — Direct AgentRouter API (more model options)
AGENT_ROUTER_TOKEN=replace_me

# For provider: "shared" — No API key needed! The shared backend holds the key.
# Just set llm.shared_backend_url in settings.yaml to your deployed proxy URL.

# ── Voice / TTS ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=replace_me

# ── Speech-to-Text ──────────────────────────────────────────────────────────
GROQ_API_KEY=replace_me
