[TEMPLATE]
# ── IRIS Environment Variables ──────────────────────────────────────────────
# Which keys you need depends on your mode setting in settings.yaml:
#
#   mode: "remote"  → No API keys needed! The shared backend holds them.
#                     Just set mode: "remote" and remote.backend_url.
#
#   mode: "local"   → Set the appropriate keys below for each service.
#                     LLM, TTS, and ASR are all independently configurable.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (used in local mode) ────────────────────────────────────────────────
# Any OpenAI-compatible API. Default is DeepSeek.
# The env var name is configurable via llm.api_key_env in settings.yaml.
DEEPSEEK_API_KEY=replace_me

# For AgentRouter (Claude models) in local mode, set:
AGENT_ROUTER_TOKEN=replace_me

# ── Voice / TTS (used in local mode) ────────────────────────────────────────
# The env var name is configurable via voice.api_key_env in settings.yaml.
ELEVENLABS_API_KEY=replace_me

# ── Speech-to-Text (used in local mode) ─────────────────────────────────────
# The env var name is configurable via asr.api_key_env in settings.yaml.
GROQ_API_KEY=replace_me

# ── Remote mode: Proxy auth token (used in remote mode) ────────────────────
# The env var name is configurable via remote.auth_token_env in settings.yaml.
IRIS_AUTH_TOKEN=replace_me
