{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRIS",
  "version": "0.1.0",
  "identifier": "com.iris.overlay",
  "build": {
    "frontendDist": ".."
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": true,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "title": "IRIS",
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:7788; script-src 'self' 'unsafe-inline'"
    }
  }
}
